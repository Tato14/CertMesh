# CertMesh configuration — copy to `.env` and fill in. NEVER commit `.env`.
# Every value below is OPTIONAL: with none set, CertMesh runs fully offline
# (deterministic agents + local vector index + MCP over public HTTP) so the
# dashboard, tests and evals all work with zero cloud provisioning.

# ── Microsoft Foundry model deployment ──────────────────────────────────────
# The project endpoint from your Foundry project (Overview ▸ Endpoints).
AZURE_AI_PROJECT_ENDPOINT=
# Name of the model deployment in your Foundry project catalog.
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o
# Optional API key. Prefer Entra ID (managed identity / `az login`) and leave
# this blank; only set it for quick local experiments.
AZURE_AI_API_KEY=

# Model backend selector: auto | foundry | offline
#   auto    — use Foundry if configured, else the deterministic offline stub
#   foundry — require Foundry (surfaces init errors instead of degrading)
#   offline — force the offline stub (used by CI / tests)
CERTMESH_MODEL_BACKEND=auto

# ── Foundry IQ knowledge base (Azure AI Search) ─────────────────────────────
# When set, the Foundry IQ layer retrieves from Azure AI Search. When blank it
# falls back to a local vector index over data/knowledge/ with the SAME
# retrieve-and-cite contract. See docs/iq-layers.md.
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=certmesh-knowledge

# ── Microsoft Learn MCP server (real Learn content, no auth) ────────────────
CERTMESH_MCP_ENABLED=true
CERTMESH_MCP_ENDPOINT=https://learn.microsoft.com/api/mcp

# ── Observability / Foundry tracing ─────────────────────────────────────────
# Set to bridge in-process spans to Foundry tracing / Azure Monitor.
APPLICATIONINSIGHTS_CONNECTION_STRING=
# Set to "true" to also print spans to the console for local debugging.
CERTMESH_TRACE_TO_CONSOLE=false
